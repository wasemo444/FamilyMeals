@page "/register"
@rendermode InteractiveAuto
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inherits LocalizedComponentBase

<PageTitle>@L["Register"]</PageTitle>

<section class="page auth-page">
    <header class="page-header">
        <h1>@L["Register"]</h1>
    </header>

    <section class="panel">
        <EditForm Model="_form" OnValidSubmit="RegisterAsync">
            <div class="form-row">
                <InputText class="input" @bind-Value="_form.DisplayName" placeholder="@L["DisplayName"]" />
            </div>
            <div class="form-row">
                <InputText class="input" @bind-Value="_form.Email" placeholder="@L["Email"]" />
            </div>
            <div class="form-row">
                <InputText class="input" type="password" @bind-Value="_form.Password" placeholder="@L["Password"]" />
            </div>
            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <p class="error">@_error</p>
            }
            <div class="form-row">
                <button class="btn primary" type="submit">@L["Register"]</button>
                <a class="btn" href="/login">@L["Login"]</a>
            </div>
        </EditForm>
    </section>
</section>
